###############################################################################
# GLOBAL NORMALIZATION
###############################################################################

# Normalisation des fins de ligne
* text=auto eol=lf

# Forcer LF pour les langages de dev
*.py     text eol=lf
*.sh     text eol=lf
*.bash   text eol=lf
*.zsh    text eol=lf
*.js     text eol=lf
*.ts     text eol=lf
*.jsx    text eol=lf
*.tsx    text eol=lf
*.css    text eol=lf
*.scss   text eol=lf
*.html   text eol=lf
*.md     text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.json   text eol=lf
*.toml   text eol=lf
*.ini    text eol=lf
*.env    text eol=lf

###############################################################################
# MARKDOWN & DOCUMENTATION
###############################################################################

# Amélioration des diffs pour Markdown
*.md     diff=markdown

# Amélioration des diffs pour JSON, YAML, TOML
*.json   diff=json
*.yml    diff=yaml
*.yaml   diff=yaml
*.toml   diff=toml

###############################################################################
# CODE & CONFIG
###############################################################################

# Scripts exécutables
*.sh     text eol=lf
*.bash   text eol=lf
*.zsh    text eol=lf

# Makefiles
Makefile text eol=lf

# Docker
Dockerfile text eol=lf
*.dockerfile text eol=lf

###############################################################################
# BINARY FILES (NE PAS DIFF)
###############################################################################

# Images
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.svg    text   # SVG = XML → diffable
*.ico    binary
*.webp   binary

# Fonts
*.ttf    binary
*.otf    binary
*.woff   binary
*.woff2  binary

# Archives
*.zip    binary
*.tar    binary
*.gz     binary
*.7z     binary

# Executables
*.exe    binary
*.dll    binary
*.so     binary
*.bin    binary

###############################################################################
# PROJECT-SPECIFIC OVERRIDES
###############################################################################

# Empêcher Git de modifier les fichiers sensibles
secrets/*  -diff -merge

# Assets du starter kit
assets/** binary

###############################################################################
# GIT LFS (OPTIONNEL)
###############################################################################
# Uncomment si tu utilises Git LFS
# *.png filter=lfs diff=lfs merge=lfs -text
# *.jpg filter=lfs diff=lfs merge=lfs -text
# *.mp4 filter=lfs diff=lfs merge=lfs -text
