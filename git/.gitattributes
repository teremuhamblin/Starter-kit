###############################################################################
# NORMALISATION GLOBALE
###############################################################################

# Normalisation automatique des fichiers texte
* text=auto eol=lf

# Langages principaux
*.py      text eol=lf diff=python
*.sh      text eol=lf
*.bash    text eol=lf
*.zsh     text eol=lf
*.ps1     text eol=lf
*.psm1    text eol=lf

# Config & infra
*.toml    text eol=lf diff=toml
*.json    text eol=lf diff=json
*.yaml    text eol=lf diff=yaml
*.yml     text eol=lf diff=yaml
*.ini     text eol=lf
*.cfg     text eol=lf
*.env     text eol=lf

###############################################################################
# DOCUMENTATION & BRANDING
###############################################################################

# Markdown premium
*.md      text eol=lf diff=markdown

# ASCII art, templates, palettes
*.txt     text eol=lf
*.ascii   text eol=lf
*.palette text eol=lf

# Licences & legal
LICENSE   text eol=lf
*.license text eol=lf

###############################################################################
# AUTOMATION & BUILD
###############################################################################

# Makefile & CI
Makefile      text eol=lf
*.mk          text eol=lf
*.workflow    text eol=lf
*.github/*    text eol=lf

# Invoke tasks
tasks.py      text eol=lf diff=python

###############################################################################
# WEB & FRONT (si modules web)
###############################################################################

*.html    text eol=lf
*.css     text eol=lf
*.scss    text eol=lf
*.js      text eol=lf
*.ts      text eol=lf

###############################################################################
# ASSETS (NE PAS DIFF)
###############################################################################

# Images
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.webp    binary
*.ico     binary

# SVG diffable (branding vectoriel)
*.svg     text

# Fonts
*.ttf     binary
*.otf     binary
*.woff    binary
*.woff2   binary

# Archives & binaires
*.zip     binary
*.tar     binary
*.gz      binary
*.7z      binary
*.bin     binary
*.exe     binary
*.dll     binary
*.so      binary

###############################################################################
# MODULES DU STARTER KIT
###############################################################################

# Branding & artefacts
branding/** text
assets/**   binary

# Secrets & tokens
secrets/*   -diff -merge

